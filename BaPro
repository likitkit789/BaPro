<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bugnil Pro Bac - Clean Pro</title>
    <style>
        :root {
            --bg: #0b0d11; --card: #161a20; --text: #d1d5db;
            --p-color: #3b82f6; --b-color: #ef4444;
            --win-color: #facc15; --lose-color: #475569;
            --accent: #facc15;
        }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 10px; display: flex; flex-direction: column; align-items: center; }
        .container { width: 100%; max-width: 800px; }

        .header-logo {
            text-align: center; margin: 5px 0 15px 0;
            font-size: 2rem; font-weight: 900; letter-spacing: 2px;
            background: linear-gradient(90deg, #3b82f6, #facc15, #ef4444);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            text-transform: uppercase;
        }

        /* Top Settings */
        .top-settings {
            display: flex; justify-content: center; gap: 10px; background: var(--card);
            padding: 10px; border-radius: 12px; margin-bottom: 10px; border: 1px solid #2d333b;
        }
        .mini-input { display: flex; flex-direction: column; align-items: center; }
        .mini-input label { font-size: 0.65rem; color: #64748b; margin-bottom: 2px; }
        .mini-input input { 
            background: #000; border: 1px solid #334155; color: var(--accent); 
            padding: 5px; border-radius: 5px; width: 65px; text-align: center; font-size: 0.85rem; 
        }

        /* DNA Rows */
        .dna-row { 
            background: #1e252f; margin-bottom: 5px; border-radius: 8px; 
            display: flex; align-items: flex-start; padding: 8px; min-height: 40px; 
        }
        .logic-label { min-width: 45px; font-weight: bold; color: #475569; font-size: 0.65rem; margin-top: 5px; }
        .rec-tag { font-size: 1.5rem; font-weight: 900; margin: 0 10px; width: 25px; text-align: center; }
        .dna-grid { display: flex; flex-wrap: wrap; gap: 3px; flex: 1; }
        .dna-dot { width: 16px; height: 16px; line-height: 16px; text-align: center; font-size: 11px; background: #000; border-radius: 3px; font-weight: bold; }
        .v { color: var(--win-color); border: 1px solid #4d451a; }
        .x { color: var(--lose-color); border: 1px solid #334155; }

        /* Game History */
        .history-bar { background: #101318; padding: 8px; border-radius: 8px; margin: 10px 0; border: 1px solid #222; text-align: center; }
        .history-list { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; }
        .hist-item { font-size: 0.9rem; font-weight: normal; }
        .h-p { color: var(--p-color); }
        .h-b { color: var(--b-color); }

        /* Controls */
        .control-grid { 
            background: #1a202a; padding: 15px; border-radius: 15px; border-bottom: 5px solid #000;
            display: flex; flex-direction: column; align-items: center;
        }
        .button-group { display: flex; gap: 10px; justify-content: center; width: 100%; margin-top: 15px; }
        .key-btn {
            width: 50px; height: 50px; border-radius: 10px; border: none; font-size: 1rem; font-weight: bold; cursor: pointer;
            box-shadow: 0 4px #000; transition: 0.1s; display: flex; align-items: center; justify-content: center;
        }
        .key-btn:active { transform: translateY(3px); box-shadow: 0 1px #000; }
        .key-p { background: var(--p-color); color: white; }
        .key-b { background: var(--b-color); color: white; }
        .key-win { background: var(--win-color); color: #000; }
        .key-loss { background: #334155; color: white; }
        .key-tool { background: #2d333b; color: #94a3b8; font-size: 0.7rem; }

        .bet-now { font-size: 3rem; font-weight: 800; color: var(--accent); margin: 5px 0; }
        
        /* Modal */
        #goalModal {
            display: none; position: fixed; z-index: 99; left: 0; top: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.95); align-items: center; justify-content: center;
        }
        .modal-content {
            background: #1a1d24; padding: 30px; border-radius: 20px; text-align: center;
            border: 2px solid var(--accent); box-shadow: 0 0 30px var(--accent); max-width: 350px;
        }
        .blink-profit { font-size: 2.5rem; font-weight: 900; color: var(--win-color); animation: blinker 0.6s linear infinite; margin: 15px 0; }
        @keyframes blinker { 50% { opacity: 0; } }
        .btn-stop { background: #ef4444; color: white; padding: 12px; border-radius: 8px; border: none; font-weight: bold; width: 100%; cursor: pointer; margin-top: 15px; }
    </style>
</head>
<body>

<div class="header-logo">Bugnil Pro Bac</div>

<div class="container">
    <div class="top-settings">
        <div class="mini-input"><label>ทุน</label><input type="number" id="capital" value="1000"></div>
        <div class="mini-input"><label>เป้า %</label><input type="number" id="targetPct" value="20"></div>
        <div class="mini-input"><label>ไม้ 1</label><input type="number" id="startBet" value="250"></div>
    </div>

    <div id="dnaContainer">
        <div class="dna-row"><div class="logic-label">SET 1</div><div class="rec-tag" id="rec1"></div><div class="dna-grid" id="dna1"></div></div>
        <div class="dna-row"><div class="logic-label">SET 2</div><div class="rec-tag" id="rec2"></div><div class="dna-grid" id="dna2"></div></div>
        <div class="dna-row"><div class="logic-label">SET 3</div><div class="rec-tag" id="rec3"></div><div class="dna-grid" id="dna3"></div></div>
    </div>

    <div class="history-bar">
        <div class="history-list" id="historyList"></div>
    </div>

    <div class="control-grid">
        <div style="text-align:center;">
            <div style="font-size: 0.7rem; color: #64748b;">NEXT BET (ไม้ <span id="currentStep">1</span>)</div>
            <div id="betDisplay" class="bet-now">250</div>
            <div style="color:var(--win-color); font-weight:bold;">กำไร: <span id="profitVal">0</span></div>
        </div>

        <div class="button-group">
            <button class="key-btn key-p" onclick="record('P')">P</button>
            <button class="key-btn key-b" onclick="record('B')">B</button>
            <button class="key-btn key-win" onclick="handleBet('WIN')">WIN</button>
            <button class="key-btn key-loss" onclick="handleBet('LOSS')">LOSS</button>
        </div>

        <div class="button-group">
            <button class="key-btn key-tool" onclick="undo()" style="width: 80px;">UNDO</button>
            <button class="key-btn key-tool" onclick="resetMoney()" style="width: 110px;">RESET MONEY</button>
            <button class="key-btn key-tool" onclick="resetAll()" style="width: 110px;">ALL RESET</button>
        </div>
    </div>
</div>

<div id="goalModal">
    <div class="modal-content">
        <h2 style="color:white; margin:0; font-size: 1.2rem;">🎯 เป้าหมายสำเร็จ!</h2>
        <div class="blink-profit" id="modalProfit">+0</div>
        <p id="alertMessage" style="color:#aaa; font-size: 0.9rem; line-height: 1.5;"></p>
        <button class="btn-stop" onclick="closeModal()">ถอนเงินและพักผ่อน</button>
    </div>
</div>

<script>
    let history = [];
    let winLevel = 0; 
    let currentProfit = 0;
    let targetAlerted = false;

    const msgs = [
        "พอแล้ว! กำไรอยู่ในมือ อย่าคืนให้เจ้ามือ ปิดโปรแกรมเดี๋ยวนี้!",
        "เป้าหมายถึงแล้ว! การฝืนเล่นต่อคือหนทางสู่ความหายนะ ไปพักซะ!",
        "วันนี้ดวงคุณพอแค่นี้... ไปหาความสุขด้านอื่นบ้าง พรุ่งนี้ค่อยมาใหม่!",
        "หยุด! อย่าปล่อยให้ความโลภทำลายกำไร ปิดหน้าจอแล้วไปอาบน้ำนอน!",
        "ชนะแล้วต้องเลิก คือวิถีของมือโปร ถ้าเล่นต่อคุณคือแมลงเม่า!"
    ];

    function record(val) { history.push(val); updateUI(); }
    function undo() { history.pop(); updateUI(); }
    function resetMoney() { currentProfit = 0; winLevel = 0; targetAlerted = false; updateUI(); }
    function resetAll() { if(confirm("ล้างทั้งหมด?")) { history = []; resetMoney(); } }

    function handleBet(status) {
        const start = parseFloat(document.getElementById('startBet').value) || 0;
        const currentBet = start * Math.pow(2, winLevel);
        if (status === 'WIN') {
            currentProfit += currentBet;
            winLevel = (winLevel + 1) >= 3 ? 0 : winLevel + 1;
        } else {
            currentProfit -= currentBet;
            winLevel = 0;
        }
        checkGoal();
        updateUI();
    }

    function checkGoal() {
        const cap = parseFloat(document.getElementById('capital').value) || 1;
        const target = parseFloat(document.getElementById('targetPct').value) || 0;
        const currentPct = (currentProfit / cap) * 100;
        if (currentPct >= target && !targetAlerted && target > 0) {
            document.getElementById('alertMessage').innerText = msgs[Math.floor(Math.random() * msgs.length)];
            document.getElementById('modalProfit').innerText = "+" + currentProfit.toLocaleString();
            document.getElementById('goalModal').style.display = 'flex';
            targetAlerted = true;
        }
    }

    function closeModal() { document.getElementById('goalModal').style.display = 'none'; resetAll(); }

    function updateUI() {
        const start = parseFloat(document.getElementById('startBet').value) || 0;
        document.getElementById('betDisplay').innerText = (start * Math.pow(2, winLevel)).toLocaleString();
        document.getElementById('currentStep').innerText = winLevel + 1;
        document.getElementById('profitVal').innerText = currentProfit.toLocaleString();
        
        document.getElementById('historyList').innerHTML = history.slice(-15).map(v => 
            `<span class="${v === 'P' ? 'h-p' : 'h-b'}">${v}</span>`).join(' ');

        for (let l = 1; l <= 3; l++) {
            let dnaHTML = "";
            for (let i = 1; i < history.length; i++) {
                let p = getPred(l, i - 1, history[i-1]);
                if (p) dnaHTML += (p === history[i]) ? '<div class="dna-dot v">✓</div>' : '<div class="dna-dot x">✕</div>';
            }
            document.getElementById(`dna${l}`).innerHTML = dnaHTML;
            let next = getPred(l, history.length - 1, history[history.length-1]);
            document.getElementById(`rec${l}`).innerHTML = next ? `<span style="color:var(--${next === 'P' ? 'p-color' : 'b-color'})">${next}</span>` : '';
        }
    }

    function getPred(l, i, last) { 
        if (!last) return null;
        if (l === 1) return last;
        if (l === 2) return last === 'P' ? 'B' : 'P';
        if (l === 3) return (Math.floor(i / 2) % 2 === 0) ? 'P' : 'B';
    }
</script>
</body>
</html>
